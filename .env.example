# Azure Blob Storage
# Copy from: Azure Portal → Storage Account → Security + networking → Access keys → Connection string
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER="uploads"

# Azure Cosmos DB
# Copy from: Azure Portal → Cosmos DB → Settings → Keys → Primary Connection String
AZURE_COSMOS_CONNECTION_STRING="AccountEndpoint=https://<account>.documents.azure.com:443/;AccountKey=<key>;"
AZURE_COSMOS_DATABASE="embedbench"

# Azure OpenAI
# Copy from: Azure Portal → Azure OpenAI → Keys and Endpoint
AZURE_OPENAI_ENDPOINT="https://embed-openai-sweden.openai.azure.com"
AZURE_OPENAI_API_KEY="<key>"
AZURE_OPENAI_DEPLOYMENT="gpt-35-turbo"

# CORS (comma-separated list for multiple origins)
CORS_ORIGINS='["http://localhost:5173"]'
